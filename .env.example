# Port to run the server on
PORT=3000

# Google AI Studio API Key (from https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# The ID of the Google Drive folder shared with the Service Account
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID

# Admin Dashboard credentials
ADMIN_PASSWORD=admin123

# Google Cloud Project Number (Required for verifying Google Chat JWT signatures)
# Found in Google Cloud Console > Project Settings
GOOGLE_CHAT_PROJECT_NUMBER=YOUR_GOOGLE_CLOUD_PROJECT_NUMBER
